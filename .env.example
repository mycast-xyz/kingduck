# Base URL of the backend API server.
# Set this for production / static deployments (e.g. GitHub Pages, Vercel, etc.)
# where the backend is NOT on the same hostname:3000 as the frontend.
# If unset, the app falls back to <current-origin>:3000 (suitable for local/LAN dev).
# Example (production): PUBLIC_API_BASE_URL=https://api.example.com
PUBLIC_API_BASE_URL=http://localhost:3000
